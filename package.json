{
  "name": "@ev3lynx/md-fabrication",
  "version": "0.6.0",
  "description": "Humanize LLM-generated markdown with vocabulary diversity, hedging, varied sentence openings, and natural conjunction starts",
  "main": "dist/cjs/cli/index.js",
  "module": "dist/esm/cli/index.js",
  "types": "dist/cjs/cli/index.d.ts",
  "bin": {
    "md-fabrication": "./dist/cjs/cli/index.js",
    "mdfab": "./dist/cjs/cli/index.js"
  },
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build:esm": "tsc --project tsconfig.esm.json",
    "typecheck": "tsc --noEmit --project tsconfig.cjs.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "node dist/cjs/cli/index.js fabricate README.md --json --dry-run"
  },
  "keywords": [
    "markdown",
    "fabrication",
    "humanize",
    "llm",
    "content",
    "writing",
    "tone",
    "voice"
  ],
  "author": "ev3lynx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ev3lynx727/micromark"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/cjs/index.d.ts"
    },
    "./cli": {
      "import": "./dist/esm/cli/index.js",
      "require": "./dist/cjs/cli/index.js",
      "types": "./dist/cjs/cli/index.d.ts"
    },
    "./core": {
      "import": "./dist/esm/core/index.js",
      "require": "./dist/cjs/core/index.js",
      "types": "./dist/cjs/core/index.d.ts"
    },
    "./transforms": {
      "import": "./dist/esm/transforms/index.js",
      "require": "./dist/cjs/transforms/index.js",
      "types": "./dist/cjs/transforms/index.d.ts"
    },
    "./modes": {
      "import": "./dist/esm/modes/index.js",
      "require": "./dist/cjs/modes/index.js",
      "types": "./dist/cjs/modes/index.d.ts"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ascii-table3": "^1.0.3",
    "commander": "^13.0.0",
    "compromise": "^14.15.1",
    "compromise-dates": "^3.8.0",
    "dependency-graph": "^1.0.0",
    "js-tiktoken": "^1.0.0",
    "js-yaml": "^4.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "eslint": "^10.4.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.60.1"
  },
  "files": [
    "dist/",
    "src/",
    "hooks.toml",
    "config.yaml",
    "README.md",
    "LICENSE",
    ".env.example"
  ]
}
