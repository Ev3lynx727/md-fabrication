# md-fabrication Environment Variables
# Copy this file to .env and configure as needed

# Path to md-fabrication.js (default: md-fabrication.js)
MD_FABRICATION_PATH=

# Default voice: casual, professional, technical (default: professional)
MD_FABRICATION_DEFAULT_VOICE=

# Max token limit for budget (default: 100000)
MD_FABRICATION_MAX_TOKENS=

# Default budget for sessions (default: 50000)
MD_FABRICATION_DEFAULT_BUDGET=
